# =========================================================
# EnterpriseAiDataAgent Backend LLM Runtime
# =========================================================

# mock is the default safe mode. Real provider failures fall back to mock.
LLM_MODE=mock
LLM_DEFAULT_PROVIDER=mock
LLM_ALLOWED_PROVIDERS=mock,deepseek,doubao,mimo
LLM_FALLBACK_PROVIDER=mock
LLM_FALLBACK_ON_ERROR=true
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# DeepSeek OpenAI-compatible provider.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Doubao / Volcano Ark OpenAI-compatible provider.
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=

# Mimo OpenAI-compatible provider.
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_MODEL=

# Legacy Anthropic settings remain optional and backend-only.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
DEFAULT_LLM_MODEL=claude-sonnet-4-5-20250929
DEFAULT_TEMPERATURE=0.3

# Backend app settings.
DUCKDB_PATH=data/enterprise.duckdb
API_KEY=
MAX_UPLOAD_BYTES=52428800
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_WINDOW_SECONDS=60
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
