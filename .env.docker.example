# =========================================================
# EnterpriseAiDataAgent — Docker Compose Environment Example
# =========================================================
# Copy to .env.docker and uncomment env_file in docker-compose.yml
# to load provider keys at runtime. The compose file defaults to
# mock LLM mode; this file is only needed for real providers.

# --- LLM Runtime (mock is the default; override for real providers) ---
# LLM_MODE=live
# LLM_DEFAULT_PROVIDER=deepseek
# LLM_FALLBACK_PROVIDER=mock

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# --- Doubao / Volcano Ark ---
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=

# --- Mimo ---
# MIMO_API_KEY=
# MIMO_BASE_URL=
# MIMO_MODEL=

# --- CORS (comma-separated origins) ---
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
