# ============================================
# Enterprise AI Data Agent - Environment Config
# ============================================

# --- LLM Runtime ---
# Mock LLM is the default safe mode. Real provider keys live only in backend env.
LLM_MODE=mock
LLM_DEFAULT_PROVIDER=mock
LLM_ALLOWED_PROVIDERS=mock,deepseek,doubao,mimo
LLM_FALLBACK_PROVIDER=mock
LLM_FALLBACK_ON_ERROR=true
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# --- DeepSeek OpenAI-compatible Provider ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Doubao / Volcano Ark OpenAI-compatible Provider ---
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=

# --- Mimo OpenAI-compatible Provider ---
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_MODEL=

# --- Legacy Anthropic API (optional, not exposed to frontend) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
DEFAULT_LLM_MODEL=claude-sonnet-4-5-20250929

DEFAULT_TEMPERATURE=0.3

# --- Database ---
DUCKDB_PATH=data/enterprise.duckdb

# --- App ---
APP_DEBUG=true
LOG_LEVEL=INFO
# Set this in deployed environments to require Authorization: Bearer <API_KEY>.
# Local development remains open when API_KEY is empty.
# API_KEY=
MAX_UPLOAD_BYTES=52428800
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_WINDOW_SECONDS=60
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For Vercel deployment, add: https://enterprise-ai-data-agent.vercel.app

# --- Frontend ---
# Backend URL for all API requests (SSE streaming + standard fetch).
# On Vercel, set this to the Render backend URL, e.g.:
#   NEXT_PUBLIC_API_URL=https://enterpriseaidataagent.onrender.com
# Default (local dev): http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_LLM_PROVIDER_SELECTOR_ENABLED=true
NEXT_PUBLIC_DEFAULT_LLM_PROVIDER=mock
NEXT_PUBLIC_ALLOWED_LLM_PROVIDERS=mock,deepseek,doubao,mimo

# --- Demo ---
# Set to true to seed demo data on first startup (idempotent)
# SEED_DEMO_DATA=true
