# ============================================
# Enterprise AI Data Agent - Environment Config
# ============================================

# --- Anthropic API (MIMO Proxy) ---
ANTHROPIC_API_KEY=REMOVED_API_KEY

ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic

DEFAULT_LLM_MODEL=mimo-v2-pro

DEFAULT_TEMPERATURE=0.7

# --- Database ---
DUCKDB_PATH=data/enterprise.duckdb

# --- RAG / Vector Store ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=enterprise_knowledge

# --- App ---
APP_DEBUG=true
LOG_LEVEL=INFO