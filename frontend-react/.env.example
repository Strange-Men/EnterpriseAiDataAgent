# =========================================================
# EnterpriseAiDataAgent Frontend Runtime
# =========================================================

# Frontend may only expose non-secret runtime values.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LLM_PROVIDER_SELECTOR_ENABLED=true
NEXT_PUBLIC_DEFAULT_LLM_PROVIDER=mock
NEXT_PUBLIC_ALLOWED_LLM_PROVIDERS=mock,deepseek,doubao,mimo

# Do not add provider API keys here.
# Real LLM keys must be configured in backend environment variables only.
